# Required environment variables for Railway deployment.
# Set these as Railway service variables (Settings → Variables).
# Shared variables can be set at the project level.

# ── Database (Railway PostgreSQL add-on provides DATABASE_URL automatically) ──
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL_SYNC=postgresql://user:pass@host:5432/dbname   # same URL, no +asyncpg

# ── Redis (Railway Redis add-on provides REDIS_URL automatically) ─────────────
REDIS_URL=redis://default:pass@host:6379
CELERY_BROKER_URL=redis://default:pass@host:6379/1
CELERY_RESULT_BACKEND=redis://default:pass@host:6379/2

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
SECRET_KEY=<generate: openssl rand -hex 32>
ALLOWED_ORIGINS=https://your-web-service.up.railway.app,https://app.uportai.com
APP_BASE_URL=https://app.uportai.com

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...
LLM_MODEL=claude-sonnet-4-6

# ── Payments ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Storage (AWS S3 for document uploads + fine-tuning exports) ───────────────
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ca-central-1
S3_BUCKET_DOCUMENTS=uportai-documents

# ── Email (AWS SES) ───────────────────────────────────────────────────────────
SES_FROM_EMAIL=noreply@uportai.com

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
LOG_LEVEL=INFO

# ── Next.js (web service only) ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-api-service.up.railway.app
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
